# Install-time artifacts: cloned or generated by setup.sh / update.sh.
# These belong to their own upstream repos and are not installer source.

# Python virtual environment built by setup.sh
/drone-venv/

# Simulator cloned per-platform by setup.sh / update.sh
/UAVNeo-Simulator/

# Library cloned from uav-neo-library
/drone-student/library/

# Labs cloned from the selected curriculum repo
/drone-student/labs/

# Per-machine runtime and local config
/drone-student/scripts/.config
/drone-student/scripts/.local_bashrc.sh
/drone-student/scripts/.logs/

# Python bytecode
__pycache__/
*.pyc
